<?xml version="1.0"?>
<robot name="diff_drive_robot" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- =========================================================== -->
  <!--  MATERIALS                                                    -->
  <!-- =========================================================== -->
  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <!-- =========================================================== -->
  <!--  BASE FOOTPRINT (ground projection of base_link)             -->
  <!-- =========================================================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- wheel radius = 0.05 m, so base_link is 0.05 m above ground -->
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================== -->
  <!--  BASE LINK  (chassis)                                        -->
  <!--  Physical size: 70 cm (L) x 50 cm (W) x 20 cm (H)          -->
  <!--  In metres   : 0.70 x 0.50 x 0.20                           -->
  <!-- =========================================================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.50 0.20"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.50 0.20"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <mass value="10.0"/>
      <!-- Box inertia: m/12*(y^2+z^2), m/12*(x^2+z^2), m/12*(x^2+y^2)
           m=10, x=0.70, y=0.50, z=0.20
           ixx = 10/12*(0.50^2+0.20^2) = 10/12*0.29  = 0.2417
           iyy = 10/12*(0.70^2+0.20^2) = 10/12*0.53  = 0.4417
           izz = 10/12*(0.70^2+0.50^2) = 10/12*0.74  = 0.6167  -->
      <inertia ixx="0.2417" ixy="0.0" ixz="0.0"
               iyy="0.4417" iyz="0.0"
               izz="0.6167"/>
    </inertial>
  </link>

  <!-- =========================================================== -->
  <!--  LEFT WHEEL                                                   -->
  <!--  Radius: 0.05 m  Width: 0.04 m                              -->
  <!--  Positioned at y = +0.27 m (half chassis width + half wheel) -->
  <!-- =========================================================== -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.5"/>
      <!-- Cylinder inertia -->
      <inertia ixx="0.000354" ixy="0.0" ixz="0.0"
               iyy="0.000354" iyz="0.0"
               izz="0.000625"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.27 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- =========================================================== -->
  <!--  RIGHT WHEEL                                                  -->
  <!--  Positioned at y = -0.27 m                                  -->
  <!-- =========================================================== -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000354" ixy="0.0" ixz="0.0"
               iyy="0.000354" iyz="0.0"
               izz="0.000625"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.27 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- =========================================================== -->
  <!--  CASTER WHEEL (front)                                        -->
  <!--  Passive ball caster at front-bottom of chassis             -->
  <!-- =========================================================== -->
  <link name="caster_front">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0000167" ixy="0.0" ixz="0.0"
               iyy="0.0000167" iyz="0.0"
               izz="0.0000167"/>
    </inertial>
  </link>

  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_front"/>
    <origin xyz="0.30 0 -0.025" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================== -->
  <!--  CASTER WHEEL (rear)                                         -->
  <!-- =========================================================== -->
  <link name="caster_rear">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0000167" ixy="0.0" ixz="0.0"
               iyy="0.0000167" iyz="0.0"
               izz="0.0000167"/>
    </inertial>
  </link>

  <joint name="caster_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_rear"/>
    <origin xyz="-0.30 0 -0.025" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================== -->
  <!--  ZED 2i CAMERA MOUNT (Using Official ZED Xacro)              -->
  <!-- =========================================================== -->
  <!-- Use zed_description's macro — zed_wrapper's version has a stale mesh path
       that points to zed_msgs (no meshes/) instead of zed_description (has meshes/). -->
  <xacro:include filename="$(find zed_description)/urdf/zed_macro.urdf.xacro" />
  
  <xacro:zed_camera name="zed" model="zed2i">
    <gnss_origin>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </gnss_origin>
  </xacro:zed_camera>

  <joint name="zed_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="zed_camera_link"/>
    <!--  Chassis box: 0.70(L) x 0.50(W) x 0.20(H), centred at z=0.10
          Top face is at z=0.20 in base_link frame.
          Camera sits exactly on top of chassis, 0.25 m forward of centre. -->
    <origin xyz="0.25 0 0.20" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================== -->
  <!--  ros2_control — REAL HARDWARE (USB Serial → ESP32)           -->
  <!--  Plugin: my_robot_hardware/SerialHardwareInterface           -->
  <!-- =========================================================== -->
  <ros2_control name="RobotSystem" type="system">
    <hardware>
      <plugin>my_robot_hardware/SerialHardwareInterface</plugin>

      <!-- Serial port where ESP32 is connected. Change if needed. -->
      <param name="serial_port">/dev/ttyUSB0</param>
      <param name="baud_rate">115200</param>
      <param name="wheel_radius">0.05</param>
      <!-- Maximum wheel speed in rad/s at full PWM=255.
           Measure this on your actual motors and tune accordingly. -->
      <param name="max_motor_speed_rad_s">10.0</param>
      <!-- Set to 'true' to run without the ESP32 (bench / CI testing).
           Commands are accepted but not sent to any serial port. -->
      <param name="use_mock_hardware">false</param>
    </hardware>

    <!-- LEFT side: represents all 3 left motors (ESP32 fans out) -->
    <joint name="left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- RIGHT side: represents all 3 right motors (ESP32 fans out) -->
    <joint name="right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
